{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "devforge",
  "version": "0.5.0",
  "identifier": "com.devforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "DevForge",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "theme": "Dark",
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {}
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "http://8.135.60.82:9527/devforge/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0N0Q2RUQ1N0EyMzAwNEQKUldSTkFDTjYxVzU5dFBnWituMGZpTDZSZlJhOW1XNjIrT1RPYjdiL1lrV2VnWFpFQ1U3blVyVU0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}